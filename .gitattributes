# Keep line endings deterministic across Windows/Linux checkouts.
* text=auto eol=lf

# Shell scripts, launchers and desktop entries MUST stay LF or they break on Linux.
*.sh            text eol=lf
*.desktop       text eol=lf
*.py            text eol=lf
linux/strix-*   text eol=lf

# Binary assets — never normalize.
*.png binary
*.ico binary
*.jpg binary
